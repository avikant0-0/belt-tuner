---
const faqs = [
  {
    question: "How tight should a 3D printer belt be?",
    answer: "A 3D printer belt should be tight enough to eliminate any slack or backlash, but loose enough that it doesn't put excessive strain on the stepper motor bearings. Instead of guessing, it is best to tune GT2 belts to a specific frequency (Hz) depending on the length of the belt."
  },
  {
    question: "What happens if a 3D printer belt is too loose?",
    answer: "If your 3D printer belt is too loose, you will experience layer shifting, dimensional inaccuracies, and backlash. This happens because the motor turns, but the belt slack prevents the toolhead from moving exactly the required distance."
  },
  {
    question: "Can a 3D printer belt be too tight?",
    answer: "Yes. An over-tightened belt will cause the stepper motor to work harder, leading to overheating and premature wear on the motor bearings. It can also stretch the belt over time, ruining its pitch, and introduce fine vertical artifacts (VFA) into your prints."
  },
  {
    question: "How do you measure belt tension in Hz?",
    answer: "You can measure belt tension in Hz using a microphone. Pluck the longest span of the belt like a guitar string, and use a pitch detection app like Belt Tuner to read the resonant frequency. Match this frequency to your printer's recommended target."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<section class="faq-section">
  <h2>Frequently Asked Questions</h2>
  
  <div class="faq-list">
    {faqs.map((faq) => (
      <details class="faq-item">
        <summary>{faq.question}</summary>
        <div class="faq-answer">
          <p>{faq.answer}</p>
        </div>
      </details>
    ))}
  </div>

  <!-- JSON-LD Structured Data for Google Rich Results -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</section>

<style>
  .faq-section {
    margin-top: var(--space-8);
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
  }
  h2 {
    color: var(--text-primary);
    font-size: 1.5rem;
    margin-bottom: var(--space-6);
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .faq-item {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  summary {
    padding: var(--space-4);
    font-weight: 600;
    color: var(--text-primary);
    cursor: pointer;
    user-select: none;
    outline: none;
    font-size: 1.05rem;
  }
  summary:hover {
    background: var(--bg-surface);
  }
  .faq-answer {
    padding: 0 var(--space-4) var(--space-4) var(--space-4);
    border-top: 1px solid var(--border);
    margin-top: var(--space-2);
    padding-top: var(--space-4);
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .faq-answer p {
    margin: 0;
  }
</style>
