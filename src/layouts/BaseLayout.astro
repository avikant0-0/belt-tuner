---
import '../styles/global.css';

const { 
  title = "Belt Tuner | 3D Printer Belt Tension Frequency Calculator", 
  description = "A free tool to measure your 3D printer belt tension using microphone pitch detection. Find the perfect belt tension Hz for Ender 3, Bambu, Prusa, and more.",
  image = "https://belttuner.com/og-image.png",
  canonicalURL = "https://belttuner.com/"
} = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content="Belt Tuner" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <main class="tool-container">
      <slot />
      
      <footer class="footer">
        <nav class="footer__nav">
          <a href="/">Tool</a>
          <a href="/submit">Submit Target</a>
          <a href="/about">About & Physics</a>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
          <a href="/contact">Contact</a>
        </nav>
        <p>&copy; {new Date().getFullYear()} Belt Tuner. This is a free community tool.</p>
        <p class="footer__credit">Belt Tuner processes audio 100% locally in your browser.</p>
      </footer>
    </main>

    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(err => {
            console.warn('Service worker registration failed:', err);
          });
        });
      }
    </script>
  </body>
</html>

<style>
  .footer {
    margin-top: auto; /* push to bottom of tool-container */
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-4);
  }

  .footer__nav a {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .footer__nav a:hover {
    color: var(--text-primary);
  }

  .footer__credit {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
  }
</style>
