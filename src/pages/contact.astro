---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact | Belt Tuner">
  <div class="contact-page">
    <h1>Contact</h1>
    <p class="description">Have a question, feedback, or just want to say hi? Send a message below or email me directly at <a href="mailto:avikantk94@gmail.com">avikantk94@gmail.com</a>.</p>

    <form id="contactForm" class="contact-form">
      <input type="hidden" name="access_key" value="4e942932-8833-4e30-a5ff-314f8946021d">
      
      <div class="form-row">
        <div class="form-group">
          <label for="name">Your Name</label>
          <input type="text" id="name" name="name" required placeholder="John Doe">
        </div>
        <div class="form-group">
          <label for="email">Your Email</label>
          <input type="email" id="email" name="email" required placeholder="john@example.com">
        </div>
      </div>

      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" required placeholder="How can I help you?"></textarea>
      </div>

      <!-- Optional: Bot spam protection -->
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

      <button type="submit" class="btn-submit">Send Message</button>
      <p id="contactResult" class="form-result" style="display: none;"></p>
    </form>
  </div>

  <style>
    .contact-page {
      padding: var(--space-4) 0;
      max-width: 600px;
      margin: 0 auto;
    }
    h1 {
      font-size: 1.5rem;
      margin-bottom: var(--space-2);
      color: var(--text-primary);
    }
    .description {
      color: var(--text-secondary);
      margin-bottom: var(--space-6);
      line-height: 1.5;
    }
    .description a {
      color: var(--color-accent);
      text-decoration: none;
    }
    .description a:hover {
      text-decoration: underline;
    }
    
    .contact-form {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      background: var(--bg-elevated);
      padding: var(--space-6);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
    }
    .form-row {
      display: flex;
      gap: var(--space-4);
    }
    @media (max-width: 600px) {
      .form-row {
        flex-direction: column;
      }
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      flex: 1;
    }
    label {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-primary);
    }
    input, textarea {
      width: 100%;
      padding: var(--space-3);
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      color: var(--text-primary);
      font-family: inherit;
      box-sizing: border-box;
    }
    input:focus, textarea:focus {
      outline: 2px solid var(--color-accent);
      border-color: transparent;
    }
    .btn-submit {
      background: var(--color-accent);
      color: white;
      border: none;
      padding: var(--space-3);
      border-radius: var(--radius-sm);
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: var(--space-2);
      transition: opacity 0.2s;
    }
    .btn-submit:hover {
      opacity: 0.9;
    }
    .btn-submit:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .form-result {
      margin-top: var(--space-2);
      font-weight: 500;
      padding: var(--space-3);
      border-radius: var(--radius-sm);
    }
    .form-result.success {
      background: hsl(142, 71%, 10%);
      color: var(--color-success);
      border: 1px solid hsl(142, 71%, 20%);
    }
    .form-result.error {
      background: hsl(0, 71%, 10%);
      color: #f87171;
      border: 1px solid hsl(0, 71%, 20%);
    }
    .form-result.loading {
      color: var(--text-secondary);
    }
  </style>

  <script>
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const result = document.getElementById('contactResult') as HTMLParagraphElement;

    if (form && result) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(form);
        const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        
        if (submitButton) {
          submitButton.textContent = 'Sending...';
          submitButton.disabled = true;
        }
        
        result.style.display = 'block';
        result.textContent = 'Please wait...';
        result.className = 'form-result loading';

        try {
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData
          });
          const data = await response.json();
          
          if (data.success) {
            result.textContent = 'Message sent successfully! I will get back to you soon.';
            result.className = 'form-result success';
            form.reset();
          } else {
            result.textContent = data.message || 'Something went wrong.';
            result.className = 'form-result error';
          }
        } catch (error) {
          result.textContent = 'Network error. Please try again later.';
          result.className = 'form-result error';
        } finally {
          if (submitButton) {
            submitButton.textContent = 'Send Message';
            submitButton.disabled = false;
          }
        }
      });
    }
  </script>
</BaseLayout>
